PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Database (uncomment when decided)
# --- PostgreSQL ---
# DATABASE_URL=postgresql://user:password@localhost:5432/sarajevo_hub
# --- MongoDB ---
# MONGODB_URI=mongodb://localhost:27017/sarajevo_hub
# --- Supabase ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_KEY=your-service-key

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:19006,http://localhost:8081

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
