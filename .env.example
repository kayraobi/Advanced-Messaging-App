# Copy to `.env` for local Expo dev. Never commit `.env`.

# Deployed test API (Swagger: https://test.sarajevoexpats.com/api/api-docs/)
EXPO_PUBLIC_API_URL=https://test.sarajevoexpats.com

# Omit or set to "false" for real API only. Only set "true" for offline mock flows.
EXPO_PUBLIC_USE_MOCK=false
